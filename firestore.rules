
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if the user is a doctor (mocking check based on user doc)
    function isDoctor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /triageSessions/{sessionId} {
      // Patients can read/write their own sessions
      // Doctors can read all sessions for triage purposes
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isDoctor());
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
