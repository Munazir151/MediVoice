
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Secure profile data for patients and healthcare practitioners.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "medicalId": { "type": "string", "description": "Practitioner registration number if applicable" },
        "bloodType": { "type": "string" },
        "age": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "TriageSession": {
      "title": "Triage Session",
      "description": "Captured voice symptoms and AI-generated clinical assessments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "nativeLanguage": { "type": "string" },
        "transcribedTextNative": { "type": "string" },
        "translatedTextEnglish": { "type": "string" },
        "severityScore": { "type": "string", "enum": ["Green", "Yellow", "Red"] },
        "guidance": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "resolved"] }
      },
      "required": ["userId", "severityScore", "guidance", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile data."
    },
    "/triageSessions/{sessionId}": {
      "schema": "TriageSession",
      "description": "Individual triage records accessible by the user and medical staff."
    }
  }
}
